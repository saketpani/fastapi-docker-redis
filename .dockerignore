# Block Python runtime byte caches
__pycache__/
*.py[cod]
*$py.class

# Block local virtual environments
.venv/
venv/
env/

# Block source control metadata and system logs
.git/
.gitignore
*.log

# Block IDE workspaces and local environment secrets
.vscode/
.idea/
.env

# Block local documentation asset images
*.jpg
*.jpeg
*.png